{
  "name": "@paperclipai/plugin-execution-improvement",
  "version": "0.1.0",
  "description": "Required system plugin that observes execution incidents and opens governance issues",
  "type": "module",
  "private": true,
  "paperclipPlugin": {
    "manifest": "./dist/src/manifest.js",
    "worker": "./dist/src/worker.js"
  },
  "scripts": {
    "prebuild": "node ../../../scripts/ensure-plugin-build-deps.mjs",
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "test": "vitest run --config ./vitest.config.ts",
    "typecheck": "pnpm --filter @paperclipai/plugin-sdk build && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@paperclipai/plugin-sdk": "workspace:*",
    "@paperclipai/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}

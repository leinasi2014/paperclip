  "pathInstructions": {
    "title": "如何获取完整路径",
    "descriptionPrefix": "请将绝对路径（例如",
    "descriptionSuffix": "）粘贴到输入框中。",
    "instructions": {
      "mac": {
        "steps": [
          "打开 Finder 并进入目标文件夹。",
          "右键点击（或按住 Control 点击）该文件夹。",
          "按住 Option（⌥）键，“复制”会变成“将路径名称拷贝为路径名”。",
          "点击“将路径名称拷贝为路径名”，然后粘贴到这里。"
        ],
        "tip": "也可以打开终端，输入 cd，把文件夹拖进终端窗口后回车，再输入 pwd 查看完整路径。"
      },
      "windows": {
        "steps": [
          "打开文件资源管理器并进入目标文件夹。",
          "点击顶部地址栏，完整路径会显示出来。",
          "复制该路径，然后粘贴到这里。"
        ],
        "tip": "或者按住 Shift 右键点击文件夹，然后选择“复制为路径”。"
      },
      "linux": {
        "steps": [
          "打开终端并使用 cd 进入目标目录。",
          "运行 pwd 输出完整路径。",
          "复制输出结果并粘贴到这里。"
        ],
        "tip": "大多数文件管理器里按 Ctrl+L 可以在地址栏中显示完整路径。"
      }
    }
  },

## Built by scripts/docker-onboard-smoke.sh, which prefetches the Claude Code
## package tarball into .tmp/docker-cache/claude-code.tgz so Docker installs it
## offline instead of stalling on npm registry fetches during image build.
FROM ubuntu:24.04

ARG NODE_MAJOR=20
ARG PAPERCLIPAI_VERSION=latest
ARG HOST_UID=10001

ENV DEBIAN_FRONTEND=noninteractive \
  PAPERCLIP_HOME=/paperclip \
  PAPERCLIP_OPEN_ON_LISTEN=false \
  HOST=0.0.0.0 \
  PORT=3100 \
  HOME=/home/paperclip \
  LANG=en_US.UTF-8 \
  LC_ALL=en_US.UTF-8 \
  NPM_CONFIG_UPDATE_NOTIFIER=false \
  NODE_MAJOR=${NODE_MAJOR} \
  PAPERCLIPAI_VERSION=${PAPERCLIPAI_VERSION}

RUN apt-get update \
  && apt-get install -y --no-install-recommends ca-certificates curl gnupg locales \
  && mkdir -p /etc/apt/keyrings \
  && curl -fsSL https://deb.nodesource.com/gpgkey/nodesource-repo.gpg.key \
    | gpg --dearmor -o /etc/apt/keyrings/nodesource.gpg \
  && echo "deb [signed-by=/etc/apt/keyrings/nodesource.gpg] https://deb.nodesource.com/node_${NODE_MAJOR}.x nodistro main" \
    > /etc/apt/sources.list.d/nodesource.list \
  && apt-get update \
  && apt-get install -y --no-install-recommends nodejs \
  && locale-gen en_US.UTF-8 \
  && groupadd --gid 10001 paperclip \
  && useradd --create-home --shell /bin/bash --uid "${HOST_UID}" --gid 10001 paperclip \
  && mkdir -p /paperclip /home/paperclip/workspace \
  && chown -R paperclip:paperclip /paperclip /home/paperclip \
  && rm -rf /var/lib/apt/lists/*

USER root
COPY .tmp/docker-cache/claude-code.tgz /tmp/claude-code.tgz
RUN mkdir -p /opt/claude-code \
  && tar -xzf /tmp/claude-code.tgz -C /opt/claude-code \
  && chmod +x /opt/claude-code/package/cli.js \
  && chmod +x /opt/claude-code/package/vendor/ripgrep/*/rg* \
  && ln -sf /opt/claude-code/package/cli.js /usr/local/bin/claude \
  && rm -f /tmp/claude-code.tgz

RUN npm install --global --omit=dev "paperclipai@${PAPERCLIPAI_VERSION}"

VOLUME ["/paperclip"]
WORKDIR /home/paperclip/workspace
EXPOSE 3100
USER paperclip

ENV CLAUDE_HOME=/home/paperclip/.claude \
  CLAUDE_CONFIG_DIR=/home/paperclip/.claude

CMD ["bash", "-lc", "set -euo pipefail; mkdir -p \"$PAPERCLIP_HOME\"; paperclipai onboard --yes --data-dir \"$PAPERCLIP_HOME\""]
